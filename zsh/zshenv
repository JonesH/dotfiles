# ~/.zshenv — the ONLY zsh config kept. bash is the login shell; zsh is unused
# interactively (last used 2025-08-31), so zshrc/zprofile were removed. This file
# exists only so the rare non-interactive `zsh -c` a tool might issue degrades
# gracefully. Sourced for every zsh invocation — keep minimal and fast.

[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# lean-ctx passthrough stubs: ensure _lc/_lc_compress exist in ALL zsh contexts
# (non-interactive subshells, eval, agent harnesses) so aliases that reference
# them degrade gracefully instead of erroring.
_lc()          { command "$@"; }
_lc_compress() { command "$@"; }
if [[ -z "$LEAN_CTX_ACTIVE" && -n "$ZSH_EXECUTION_STRING" ]] && command -v lean-ctx &>/dev/null; then
  if [[ -n "$LEAN_CTX_AGENT" || -n "$CLAUDECODE" || -n "$CODEX_CLI_SESSION" || -n "$GEMINI_SESSION" ]]; then
    export LEAN_CTX_ACTIVE=1
    exec lean-ctx -c "$ZSH_EXECUTION_STRING"
  fi
fi
