# ~/.bash_profile — login shell. Defer to ~/.bashrc for the real config.

[ -r "$HOME/.bashrc" ] && . "$HOME/.bashrc"

# iTerm2 shell integration (only when actually running inside iTerm2)
if [ "${TERM_PROGRAM:-}" = "iTerm.app" ]; then
  [ -e "$HOME/.iterm2_shell_integration.bash" ] && . "$HOME/.iterm2_shell_integration.bash"
fi
